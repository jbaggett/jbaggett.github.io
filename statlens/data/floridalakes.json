{
  "id": "floridalakes",
  "name": "Florida Lakes (Mercury)",
  "description": "Water chemistry and fish mercury for 53 Florida lakes — pH/alkalinity vs mercury (Ch. 7, 24 regression/correlation).",
  "source": "coursepack",
  "chapter": "IMS Ch. 7, 24",
  "type": "regression",
  "studyDescription": "For 53 Florida lakes, researchers recorded water-chemistry measures (pH, alkalinity, calcium, chlorophyll) and the average mercury concentration measured in fish tissue. An observational study used to relate acidity to fish mercury.",
  "variableDescriptions": {
    "lake": "Name of the lake.",
    "alkalinity": "Water alkalinity (acid-neutralizing capacity).",
    "ph": "Water acidity/alkalinity on the pH scale.",
    "calcium": "Dissolved calcium concentration.",
    "chlorophyll": "Chlorophyll concentration (algae/productivity).",
    "avg_mercury": "Mean mercury concentration in fish tissue.",
    "std_mercury": "Mercury standardized to a 3-year-old fish.",
    "age_data": "Whether fish-age data were available (1 = yes, 0 = no)."
  },
  "sourceDetail": "Lange, Royals & Connor (1993), via Mendenhall & Sincich and the coursepack.",
