{
  "id": "ask",
  "name": "iPod Question Framing",
  "description": "219 participants: does framing an iPod purchase question differently affect the decision? Three question types (control, give up, keep) x two outcomes. IMS Ch. 18.",
  "source": "IMS (Introduction to Modern Statistics)",
  "variables": [
    {
      "name": "question",
      "type": "categorical"
    },
    {
      "name": "decision",
      "type": "categorical"
    }
  ],
  "studyDescription": "In a randomized experiment, 219 participants were presented with one of three differently worded questions about purchasing a video iPod: a control question, a \"give up\" framing (emphasizing what they would lose), or a \"keep\" framing (emphasizing what they would retain). Each participant then decided whether or not to buy the iPod.",
  "variableDescriptions": {
    "question": "How the purchase question was framed: control (neutral wording), give_up (emphasizing what would be given up), or keep (emphasizing what would be kept)",
    "decision": "Whether the participant decided to buy the iPod or not buy it"
  },
  "sourceDetail": "IMS (Introduction to Modern Statistics) Ch. 18. Original study: Frederick S, Novemsky N, Wang J, Dhar R, Nowlis S (2009), \"Opportunity Cost Neglect,\" Journal of Consumer Research, 36(4):553-561.",
  "context": {
    "population": "study participants",
    "parameter": "association between question framing and purchase decision",
    "nullClaim": "question framing and purchase decision are independent",
    "successLabel": "buy"
  },
